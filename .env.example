# Copy to .env — never commit .env

# Polymarket CLOB (required for LP mode)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=2

# Optional: Kalshi (alert-only cross-venue scanner)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Runtime (no secrets)
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
DRY_RUN=true
LOG_LEVEL=INFO

# Capital guardrails
MAX_NOTIONAL_PER_MARKET_USD=2000
MIN_HOURS_BEFORE_KICKOFF=10

# Conviction YAML (team tiers — not prices)
CONVICTION_CONFIG=config/conviction.yaml

# Operating thresholds (calendar, bilateral, fill handler — not live prices)
OPERATING_CONFIG=config/operating.yaml
LOGIC_VERSION_CONFIG=config/strategy_logic_versions.yaml
LEDGER_PATH=data/local/ledger.jsonl
