[Unit]
Description=World Cup Bot conviction scan (Gamma)
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=@INSTALL_ROOT@
EnvironmentFile=-@INSTALL_ROOT@/.env
Environment=WC_DRY_RUN=true
ExecStart=/bin/bash -c '@INSTALL_ROOT@/bin/wc_run.sh scan --conviction >> @INSTALL_ROOT@/logs/cron_scan.log 2>&1'
User=root
