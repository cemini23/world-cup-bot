# Copy to .env — never commit .env

# Polymarket CLOB (required for LP mode)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=2

# L2 API creds (required for `watch` + live POST — derive from private key once)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Signer EOA for L2 POLY_ADDRESS header (optional if private key set + eth-account installed)
# POLYMARKET_POLY_ADDRESS=

# Optional: Kalshi (alert-only cross-venue scanner)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Runtime (no secrets)
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_USER_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
DRY_RUN=true
LOG_LEVEL=INFO

# Capital guardrails
MAX_NOTIONAL_PER_MARKET_USD=2000
MIN_HOURS_BEFORE_KICKOFF=10

# Conviction YAML (team tiers — not prices)
CONVICTION_CONFIG=config/conviction.yaml

# Operating thresholds (calendar, bilateral, fill handler — not live prices)
OPERATING_CONFIG=config/operating.yaml

# Module 6 cross-venue scanner (alert-only — not live prices)
CROSS_VENUE_CONFIG=config/cross_venue.yaml
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Optional operator alerts (Discord/Slack webhook JSON POST)
# WC_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# PnL attribution (K75 — bump version on logic changes)
LOGIC_VERSION_CONFIG=config/strategy_logic_versions.yaml
LEDGER_PATH=data/local/ledger.jsonl
# VPS shadow soak (systemd sets WC_LEDGER_PATH → data/local/shadow_ledger.jsonl)
# WC_LEDGER_PATH=data/local/shadow_ledger.jsonl

# Paper cross-venue arb ledger (cross-venue-scan --record)
# WC_CROSS_VENUE_LEDGER_PATH=data/local/cross_venue_arb_ledger.jsonl

# Optional LLM advisor — leave unset for zero API cost (see SETUP.md)
# ADVISOR_BASE_URL=http://localhost:11434/v1
# ADVISOR_API_KEY=
# ADVISOR_MODEL=llama3.2
# ADVISOR_TIMEOUT_SEC=60
# ADVISOR_PROMPT=prompts/advisor.md
