[Unit]
Description=World Cup Bot cross-venue discover-only (new PM↔Kalshi pairs)
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=@INSTALL_ROOT@
EnvironmentFile=-@INSTALL_ROOT@/.env
Environment=WC_DRY_RUN=true
ExecStart=/bin/bash -c '@INSTALL_ROOT@/bin/wc_run.sh cross-venue-scan --discover-only >> @INSTALL_ROOT@/logs/cron_discover.log 2>&1'
User=root
